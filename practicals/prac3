def run_statistics():
    """Run statistics for AI performance"""
    print("\nRunning AI Statistics...")
    print("=" * 50)
    
    stats = {'X_wins': 0, 'O_wins': 0, 'ties': 0}
    games_to_play = 100
    
    for _ in range(games_to_play):
        player_x = HardAI('X')
        player_o = HardAI('O')
        result = play_game(player_x, player_o, print_game=False)
        
        if result == 'X':
            stats['X_wins'] += 1
        elif result == 'O':
            stats['O_wins'] += 1
        else:
            stats['ties'] += 1
    
    print(f"\nResults after {games_to_play} games:")
    print(f"X wins: {stats['X_wins']} ({stats['X_wins']/games_to_play*100:.1f}%)")
    print(f"O wins: {stats['O_wins']} ({stats['O_wins']/games_to_play*100:.1f}%)")
    print(f"Ties: {stats['ties']} ({stats['ties']/games_to_play*100:.1f}%)")
    print("\nHard AI vs Hard AI always results in ties with perfect play!")

