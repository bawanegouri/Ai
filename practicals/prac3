import math
import random

class TicTacToe:
    def __init__(self):
        self.board = [' ' for _ in range(9)]  # 3x3 board represented as list
        self.current_winner = None
    
    def print_board(self):
        """Print the current board state"""
        for row in [self.board[i*3:(i+1)*3] for i in range(3)]:
            print('| ' + ' | '.join(row) + ' |')
    
    def print_board_nums(self):
        """Print board with position numbers (0-8)"""
        number_board = [[str(i) for i in range(j*3, (j+1)*3)] for j in range(3)]
        for row in number_board:
            print('| ' + ' | '.join(row) + ' |')
    
    def available_moves(self):
        """Return list of available positions"""
        return [i for i, spot in enumerate(self.board) if spot == ' ']
    
    def empty_squares(self):
        """Check if there are empty squares"""
        return ' ' in self.board
    
    def num_empty_squares(self):
        """Count empty squares"""
        return self.board.count(' ')
    
    def make_move(self, square, letter):
        """Make a move on the board"""
        if self.board[square] == ' ':
            self.board[square] = letter
            if self.winner(square, letter):
                self.current_winner = letter
            return True
        return False
    
    def winner(self, square, letter):
        """Check if the move resulted in a win"""
        # Check row
        row_ind = square // 3
        row = self.board[row_ind*3:(row_ind+1)*3]
        if all([spot == letter for spot in row]):
            return True
        
        # Check column
        col_ind = square % 3
        column = [self.board[col_ind+i*3] for i in range(3)]
        if all([spot == letter for spot in column]):
            return True
        
        # Check diagonals
        if square % 2 == 0:
            diagonal1 = [self.board[i] for i in [0, 4, 8]]
            if all([spot == letter for spot in diagonal1]):
                return True
            diagonal2 = [self.board[i] for i in [2, 4, 6]]
            if all([spot == letter for spot in diagonal2]):
                return True
        
        return False

class AIPlayer:
    def __init__(self, letter):
        self.letter = letter
        self.opponent_letter = 'O' if letter == 'X' else 'X'
    
    def get_move(self, game):
        """Get the best move using minimax algorithm"""
        if len(game.available_moves()) == 9:
            # First move: choose center or corner
            square = random.choice([0, 2, 4, 6, 8])  # Prefer center and corners
        else:
            # Use minimax for optimal move
            square = self.minimax(game, self.letter)['position']
        return square
    
    def minimax(self, state, player):
        """
        Minimax algorithm implementation
        Returns the best move as {'position': None, 'score': score}
        """
        max_player = self.letter
        other_player = 'O' if player == 'X' else 'X'
        
        # Base cases
        if state.current_winner == other_player:
            return {'position': None, 'score': 1 * (state.num_empty_squares() + 1) if other_player == max_player else -1 * (state.num_empty_squares() + 1)}
        elif not state.empty_squares():
            return {'position': None, 'score': 0}
        
        if player == max_player:
            best = {'position': None, 'score': -math.inf}
        else:
            best = {'position': None, 'score': math.inf}
        
        for possible_move in state.available_moves():
            # Make a move
            state.make_move(possible_move, player)
            
            # Simulate game after making that move
            sim_score = self.minimax(state, other_player)
            
            # Undo move
            state.board[possible_move] = ' '
            state.current_winner = None
            sim_score['position'] = possible_move
            
            # Update best score
            if player == max_player:
                if sim_score['score'] > best['score']:
                    best = sim_score
            else:
                if sim_score['score'] < best['score']:
                    best = sim_score
        
        return best

class HumanPlayer:
    def __init__(self, letter):
        self.letter = letter
    
    def get_move(self, game):
        """Get human player's move"""
        valid_square = False
        val = None
        while not valid_square:
            square = input(f"{self.letter}'s turn. Input move (0-8): ")
            try:
                val = int(square)
                if val not in game.available_moves():
                    raise ValueError
                valid_square = True
            except ValueError:
                print("Invalid square. Try again.")
        return val

class RandomAIPlayer:
    def __init__(self, letter):
        self.letter = letter
    
    def get_move(self, game):
        """Get random move for easy AI"""
        square = random.choice(game.available_moves())
        return square

def play_game(player_x, player_o, print_game=True):
    """Main game function"""
    game = TicTacToe()
    letter = 'X'
    
    while game.empty_squares():
        if letter == 'O':
            square = player_o.get_move(game)
        else:
            square = player_x.get_move(game)
        
        if game.make_move(square, letter):
            if print_game:
                print(f"{letter} made a move to square {square}")
                game.print_board()
                print('')
            
            if game.current_winner:
                if print_game:
                    print(f"{letter} wins!")
                return letter
            
            # Switch players
            letter = 'O' if letter == 'X' else 'X'
    
    if print_game:
        print("It's a tie!")
    return None

# ==================== DIFFICULTY LEVELS ====================

class EasyAI(RandomAIPlayer):
    """Easy AI - makes random moves"""
    pass

class HardAI(AIPlayer):
    """Hard AI - uses minimax algorithm (unbeatable)"""
    pass

class MediumAI:
    """Medium AI - blocks wins and tries to win, but not optimal"""
    def __init__(self, letter):
        self.letter = letter
        self.opponent_letter = 'O' if letter == 'X' else 'X'
    
    def get_move(self, game):
        """Medium difficulty: tries to win or block, otherwise random"""
        # Try to win
        for move in game.available_moves():
            game_copy = self._simulate_move(game, move, self.letter)
            if game_copy.current_winner == self.letter:
                return move
        
        # Try to block opponent
        for move in game.available_moves():
            game_copy = self._simulate_move(game, move, self.opponent_letter)
            if game_copy.current_winner == self.opponent_letter:
                return move
        
        # Take center if available
        if 4 in game.available_moves():
            return 4
        
        # Take corners
        corners = [0, 2, 6, 8]
        available_corners = [c for c in corners if c in game.available_moves()]
        if available_corners:
            return random.choice(available_corners)
        
        # Random move
        return random.choice(game.available_moves())
    
    def _simulate_move(self, game, move, letter):
        """Simulate a move without changing original game"""
        game_copy = TicTacToe()
        game_copy.board = game.board.copy()
        game_copy.current_winner = game.current_winner
        game_copy.make_move(move, letter)
        return game_copy

